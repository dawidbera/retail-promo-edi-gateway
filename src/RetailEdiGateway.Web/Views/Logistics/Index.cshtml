@{
 ViewData["Title"] = "WMS Unloading Schedule";
 var slots = ViewBag.Slots as List<RetailEdiGateway.Core.Entities.WarehouseSlot> ?? new();
 var pendingLines = ViewBag.PendingLines as List<RetailEdiGateway.Core.Entities.PurchaseOrderLine> ?? new();
}

<div class="header-section">
 <div class="page-title">
 <h1>WMS Unloading Schedule</h1>
 <p>Delivery window reservation and bottleneck prevention at unloading bays</p>
 </div>
</div>

<!-- TempData Notification Alerts -->
@if (TempData["SuccessMessage"] != null)
{
 <div class="temp-alert temp-alert-success">
 ✅ @TempData["SuccessMessage"]
 </div>
}
@if (TempData["ErrorMessage"] != null)
{
 <div class="temp-alert temp-alert-error">
 ❌ @TempData["ErrorMessage"]
 </div>
}
@if (TempData["WarningMessage"] != null)
{
 <div class="temp-alert temp-alert-warning">
 ⚠️ @TempData["WarningMessage"]
 </div>
}

<div class="booking-grid">
 <!-- Booking Reservation Form -->
 <div class="glass-card">
 <h2 style="font-size: 1.25rem; font-weight: 700; margin-bottom: 1.5rem; color: #fff;">Book Delivery Window</h2>
 
 @if (!pendingLines.Any())
 {
 <p style="color: var(-color-text-muted); padding: 1rem 0;">All order lines already have unloading slots assigned.</p>
 }
 else
 {
 <form action="@Url.Action("Book", "Logistics")" method="post" class="booking-form">
 <label style="display: block; font-size: 0.85rem; color: var(-color-text-muted); margin-bottom: 0.5rem; font-weight: 500;">
 Select Order Line
 </label>
 <select name="purchaseOrderLineId" required>
 @foreach (var line in pendingLines)
 {
 <option value="@line.Id">
 @line.ProductCode - @line.ProductName (@line.PurchaseOrder.Supplier.Name | PO: @line.PurchaseOrder.ErpOrderNumber)
 </option>
 }
 </select>

 <label style="display: block; font-size: 0.85rem; color: var(-color-text-muted); margin-bottom: 0.5rem; font-weight: 500;">
 Distribution Center (DC)
 </label>
 <select name="dcCode" required>
 <option value="DC-LND1">DC London 1 (Heathrow)</option>
 <option value="DC-MAN2">DC Manchester 2 (Trafford)</option>
 <option value="DC-BRS3">DC Bristol 3 (Filton)</option>
 </select>

 <label style="display: block; font-size: 0.85rem; color: var(-color-text-muted); margin-bottom: 0.5rem; font-weight: 500;">
 Delivery Date and Time
 </label>
 <input type="datetime-local" name="bookedTime" required />

 <label style="display: block; font-size: 0.85rem; color: var(-color-text-muted); margin-bottom: 0.5rem; font-weight: 500;">
 Bay Number
 </label>
 <select name="bayNumber" required>
 <option value="Bay 01">Bay 01</option>
 <option value="Bay 02">Bay 02</option>
 <option value="Bay 03">Bay 03</option>
 <option value="Bay 04">Bay 04</option>
 <option value="Bay 05">Bay 05</option>
 </select>

 <button type="submit" class="btn-primary" style="margin-top: 1rem; width: 100%;">Book Window in WMS</button>
 </form>
 }
 </div>

 <!-- Active Reservations Table View -->
 <div class="glass-card">
 <h2 style="font-size: 1.25rem; font-weight: 700; margin-bottom: 1.5rem; color: #fff;">Reserved Unloading Slots</h2>
 
 @if (!slots.Any())
 {
 <p style="color: var(-color-text-muted); padding: 1rem 0; text-align: center;">No reserved slots in the system.</p>
 }
 else
 {
 <div style="overflow-x: auto;">
 <table class="data-table">
 <thead>
 <tr>
 <th>Center (DC)</th>
 <th>Delivery Date</th>
 <th>Bay</th>
 <th>Supplier</th>
 <th>Article</th>
 <th>Status</th>
 </tr>
 </thead>
 <tbody>
 @foreach (var slot in slots)
 {
 <tr>
 <td><strong>@slot.DcCode</strong></td>
 <td>@slot.BookedTime.ToString("dd.MM.yyyy HH:mm")</td>
 <td><span style="color: var(-accent-cyan); font-weight: 600;">@slot.BayNumber</span></td>
 <td>
 <div style="font-weight: 500;">@slot.PurchaseOrderLine.PurchaseOrder.Supplier.Name</div>
 <div style="font-size: 0.75rem; color: var(-color-text-muted);">ERP PO: @slot.PurchaseOrderLine.PurchaseOrder.ErpOrderNumber</div>
 </td>
 <td>
 <div>@slot.PurchaseOrderLine.ProductName</div>
 <div style="font-size: 0.75rem; color: var(-color-text-muted);">EAN: @slot.PurchaseOrderLine.ProductCode</div>
 </td>
 <td>
 <span class="badge badge-confirmed" style="padding: 0.2rem 0.5rem; font-size: 0.65rem;">@slot.Status</span>
 </td>
 </tr>
 }
 </tbody>
 </table>
 </div>
 }
 </div>
</div>
